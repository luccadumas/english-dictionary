DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dictionary"

# Option A: single URL (Railway Redis plugin)
# REDIS_URL=redis://default:password@localhost:6379

# Option B: individual vars (local Docker)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
PORT=3333
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
