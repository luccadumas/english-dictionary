# Production example — Railway / Docker prod
# Copy values into your hosting provider dashboard (never commit real secrets).

DATABASE_URL=postgresql://user:password@host:5432/dictionary

# Option A: Railway Redis plugin (recommended)
REDIS_URL=redis://default:password@host:6379

# Option B: individual Redis vars
# REDIS_HOST=host
# REDIS_PORT=6379
# REDIS_PASSWORD=password

JWT_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=7d
PORT=3333
NODE_ENV=production

# Vercel URL(s) — comma-separated if you have preview deployments
CORS_ORIGIN=https://your-app.vercel.app
